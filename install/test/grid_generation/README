TITLE: VDW/ES Grid generation

EXECUTABLES TESTED:  
	showbox
	grid
	
WALL CLOCK TIME:
	4.23 secs

FILES USED:
	box.in			#input file for showbox
	struct.sph		#sphere file that box is built around
	grid.in			#input file for grid
	rec.mol2		#structure file used to create grid
	vdw.defn		#vdw parameter file used to create grid

FILES GENERATED:
	box.pdb			#coordinates for box generated by showbox
	grid.bmp		#bump grid file generated by grid
	grid.cnt		#contact grid file generated by grid
	grid.nrg		#energy grid file generated by grid
