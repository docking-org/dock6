# DOCK configuration file for IBM XL compilers on Blue Gene/L
# with MPI based parallelism (specifically MPICH2 but should for all MPIs).

# CC is the C compiler
# CFLAGS is the flags for the C compiler
# CXX is the C++ compiler
# CXXFLAGS is the flags for the C++ compiler
# FC is the Fortran compiler
# FFLAGS is the flags for the Fortran compiler
# LIBS is the flags for the linker
# SFX is the suffix for the executable

BGL_SYS=     /bgl/BlueLight/ppcfloor/bglsys
CC=          /opt/ibmcmp/vac/bg/9.0/bin/blrts_xlc
CFLAGS=      -qcheck=all -DBUILD_DOCK_WITH_MPI \
             -I$(BGL_SYS)/include -lmassv -qarch=440d -qtune=440 \
             -qignprag=omp -qinline -qflag=w:w -O5 -qlist -qsource -qhot
CXX=         /opt/ibmcmp/vacpp/bg/9.0/bin/blrts_xlC
CXXFLAGS=    -qcheck=all -DBUILD_DOCK_WITH_MPI -DMPICH_IGNORE_CXX_SEEK \
             -I$(BGL_SYS)/include -lmassv -qarch=440d -qtune=440 \
             -qignprag=omp -qinline -qflag=w:w -O5 -qlist -qsource -qhot

FC=          /opt/ibmcmp/xlf/bg/10.1/bin/blrts_xlf90
FFLAGS=      $(XLC_TRACE_LIB) -O3 -qlist -qsource  -qhot -fno-automatic \
             -fno-second-underscore -qarch-440d -O3  -qlist -qsource -qhot \
             -qlist -fno-automatic  -fno-second-underscore

LOAD=        /opt/ibmcmp/vacpp/bg/9.0/bin/blrts_xlC
LIBS=        -lm -L$(BGL_SYS)/lib -lmpich.rts -lmsglayer.rts -lrts.rts -ldevices.rts
SFX=         .bgl.mpi

# Macro definitions for NAB
# AR is the library archiver
# LEX is the lexical analyzer generator
# OCFLAGS is the flags for the C compilers with high optimization
# RANLIB is the library index generator

AR=          ar rv
LEX=         flex
OCFLAGS=     -D_ANSI_SOURCE
RANLIB=      ranlib
